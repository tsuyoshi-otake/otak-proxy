{
  "name": "otak-proxy",
  "displayName": "otak-proxy",
  "description": "%extension.description%",
  "publisher": "odangoo",
  "license": "MIT",
  "icon": "images/otak-proxy-icon-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsuyoshi-otake/otak-proxy"
  },
  "bugs": {
    "url": "https://github.com/tsuyoshi-otake/otak-proxy/issues"
  },
  "homepage": "https://github.com/tsuyoshi-otake/otak-proxy#readme",
  "version": "3.1.4",
  "files": [
    "out/extension.js",
    "out/commands/**/*.js",
    "out/config/**/*.js",
    "out/core/**/*.js",
    "out/diagnostics/**/*.js",
    "out/errors/**/*.js",
    "out/i18n/**/*.js",
    "out/i18n/locales/*.json",
    "out/monitoring/**/*.js",
    "out/remediation/**/*.js",
    "out/security/**/*.js",
    "out/sync/**/*.js",
    "out/ui/**/*.js",
    "out/utils/**/*.js",
    "out/validation/**/*.js",
    "images/**",
    "sounds/**",
    "package.nls*.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "otak-proxy.toggleProxy",
        "title": "%command.toggleProxy%"
      },
      {
        "command": "otak-proxy.testProxy",
        "title": "%command.testProxy%"
      },
      {
        "command": "otak-proxy.importProxy",
        "title": "%command.importProxy%"
      },
      {
        "command": "otak-proxy.configureUrl",
        "title": "%command.configureUrl%"
      },
      {
        "command": "otak-proxy.toggleShowProxyUrl",
        "title": "%command.toggleShowProxyUrl%"
      },
      {
        "command": "otak-proxy.diagnoseProxy",
        "title": "%command.diagnoseProxy%"
      },
      {
        "command": "otak-proxy.resetWinHttpProxy",
        "title": "%command.resetWinHttpProxy%"
      }
    ],
    "configuration": {
      "title": "otak-proxy",
      "properties": {
        "otakProxy.proxyUrl": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "%config.proxyUrl%"
        },
        "otakProxy.pollingInterval": {
          "type": "number",
          "default": 30,
          "minimum": 10,
          "maximum": 300,
          "scope": "machine-overridable",
          "description": "%config.pollingInterval%"
        },
        "otakProxy.detectionSourcePriority": {
          "type": "array",
          "default": [
            "environment",
            "vscode",
            "platform"
          ],
          "items": {
            "type": "string",
            "enum": [
              "environment",
              "vscode",
              "platform"
            ]
          },
          "scope": "machine",
          "description": "%config.detectionSourcePriority%"
        },
        "otakProxy.maxRetries": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "maximum": 10,
          "scope": "machine-overridable",
          "description": "%config.maxRetries%"
        },
        "otakProxy.testInterval": {
          "type": "number",
          "default": 60,
          "minimum": 30,
          "maximum": 600,
          "scope": "machine-overridable",
          "description": "%config.testInterval%"
        },
        "otakProxy.autoTestEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "machine-overridable",
          "description": "%config.autoTestEnabled%"
        },
        "otakProxy.enableFallback": {
          "type": "boolean",
          "default": true,
          "scope": "machine-overridable",
          "description": "%config.enableFallback%"
        },
        "otakProxy.showProxyUrl": {
          "type": "boolean",
          "default": true,
          "scope": "machine-overridable",
          "description": "%config.showProxyUrl%"
        },
        "otakProxy.statusBarTooltip": {
          "type": "boolean",
          "default": true,
          "scope": "machine-overridable",
          "description": "%config.statusBarTooltip%"
        },
        "otakProxy.syncEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "machine",
          "description": "%config.syncEnabled%"
        },
        "otakProxy.syncInterval": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 5000,
          "scope": "machine-overridable",
          "description": "%config.syncInterval%"
        },
        "otakProxy.diagnosticsEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "machine",
          "description": "%config.diagnosticsEnabled%"
        },
        "otakProxy.automaticRemediationEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "machine",
          "description": "%config.automaticRemediationEnabled%"
        },
        "otakProxy.hostUserLockEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "machine",
          "description": "%config.hostUserLockEnabled%"
        },
        "otakProxy.automaticRetryEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "machine",
          "description": "%config.automaticRetryEnabled%"
        },
        "otakProxy.remediationDelayedRetryMs": {
          "type": "number",
          "default": 2000,
          "minimum": 250,
          "maximum": 30000,
          "scope": "machine",
          "description": "%config.remediationDelayedRetryMs%"
        },
        "otakProxy.remediationFlapWindowMs": {
          "type": "number",
          "default": 600000,
          "minimum": 60000,
          "maximum": 3600000,
          "scope": "machine",
          "description": "%config.remediationFlapWindowMs%"
        },
        "otakProxy.remediationFlapMaxAttempts": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 10,
          "scope": "machine",
          "description": "%config.remediationFlapMaxAttempts%"
        },
        "otakProxy.remediationFlapCooldownMs": {
          "type": "number",
          "default": 600000,
          "minimum": 60000,
          "maximum": 7200000,
          "scope": "machine",
          "description": "%config.remediationFlapCooldownMs%"
        },
        "otakProxy.notificationCooldownMs": {
          "type": "number",
          "default": 600000,
          "minimum": 10000,
          "maximum": 7200000,
          "scope": "machine",
          "description": "%config.notificationCooldownMs%"
        },
        "otakProxy.slowDiagnosticsTtlMs": {
          "type": "number",
          "default": 300000,
          "minimum": 30000,
          "maximum": 3600000,
          "scope": "machine",
          "description": "%config.slowDiagnosticsTtlMs%"
        },
        "otakProxy.terminalOffMaskingEnabled": {
          "type": "boolean",
          "default": true,
          "scope": "machine",
          "description": "%config.terminalOffMaskingEnabled%"
        },
        "otakProxy.notificationLevel": {
          "type": "string",
          "default": "warnings",
          "enum": [
            "off",
            "important",
            "warnings",
            "all"
          ],
          "scope": "machine-overridable",
          "description": "%config.notificationLevel%"
        },
        "otakProxy.windowsActionsEnabled": {
          "type": "boolean",
          "default": false,
          "scope": "machine",
          "description": "%config.windowsActionsEnabled%"
        },
        "otakProxy.credentialTargetPolicy": {
          "type": "string",
          "default": "ask",
          "enum": [
            "ask",
            "allowPlaintextTargets",
            "blockPlaintextTargets"
          ],
          "scope": "machine",
          "description": "%config.credentialTargetPolicy%"
        },
        "otakProxy.legacyEnvFirstAutoDetection": {
          "type": "boolean",
          "default": true,
          "scope": "machine",
          "description": "%config.legacyEnvFirstAutoDetection%"
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true,
      "description": "This extension manages VSCode, Git, npm proxy settings and integrated terminal proxy env vars"
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "gen:nls": "node scripts/gen-package-nls.mjs",
    "compile": "npm run gen:nls && tsc -p ./ && node -e \"require('fs').cpSync('src/i18n/locales', 'out/i18n/locales', {recursive: true})\"",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "cross-env NODE_OPTIONS=--max-old-space-size=8192 eslint src",
    "test": "vscode-test",
    "test:fast": "cross-env OTAK_PROXY_TEST_FAST=1 vscode-test --bail",
    "test:vscode": "npm run compile && vscode-test",
    "test:vscode:fast": "npm run compile && cross-env OTAK_PROXY_TEST_FAST=1 vscode-test --bail",
    "test:smoke": "npm run compile && cross-env OTAK_PROXY_TEST_FAST=1 MOCHA_GREP=@smoke vscode-test --bail",
    "test:mvp": "npm run lint && npm run test:unit:parallel && npm run test:smoke",
    "test:ci": "npm run lint && npm test",
    "test:unit": "npm run compile && node scripts/run-unit-tests.mjs",
    "test:unit:parallel": "npm run compile && cross-env OTAK_PROXY_UNIT_PARALLEL=1 node scripts/run-unit-tests.mjs",
    "test:real-proxy": "dotenvx run -f .env.local -- cross-env MOCHA_GREP=\"Real Proxy\" vscode-test"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.97.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vscode/test-cli": "0.0.11",
    "@vscode/test-electron": "^2.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.19.0",
    "fast-check": "^4.3.0",
    "mocha": "^11.3.0",
    "sinon": "^21.1.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "@vscode/test-cli": {
      "mocha": "11.3.0"
    },
    "serialize-javascript": "^7.0.5"
  }
}
